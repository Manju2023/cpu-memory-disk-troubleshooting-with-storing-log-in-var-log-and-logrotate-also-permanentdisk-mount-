<configuration>

    <!-- Log directory -->
    <property name="LOG_PATH" value="/var/log/myapp"/>

    <!-- FILE appender (NO rolling policy) -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">

        <!-- Main log file -->
        <file>${LOG_PATH}/app.log</file>

        <!-- Append logs (do not overwrite on restart) -->
        <append>true</append>

        <!-- Log format -->
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger - %msg%n</pattern>
        </encoder>

    </appender>

    <!-- Console logs (optional but useful) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>